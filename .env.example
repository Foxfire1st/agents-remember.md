# Agents Remember shared-mode path configuration
#
# Normal first-run setup is repo-local and does not require AR_MANAGEMENT_ROOT.
# Use this file only when you explicitly want shared scaffolding for one or
# more repositories. Relative paths resolve from this .env file.
#
# Copy this file to .env only when you want to customize shared mode.
# The .env file is intentionally ignored because it is local machine config.

AR_MANAGEMENT_ROOT=../ar-management